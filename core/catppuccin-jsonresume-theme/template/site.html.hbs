<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>
			{{basics.name}}{{#if basics.label}} &ndash; {{basics.label}}{{/if}}
		</title>
		{{#if basics.image}}
		<link rel="icon" type="image/png" href="{{basics.image}}" />
		{{/if}}
		<style>
			{{{style}}}
		</style>
		<script data-cfasync="false">
			(function () {
				const savedTheme = localStorage.getItem("theme") || "system";
				if (savedTheme === "dark") {
					document.documentElement.classList.add("mocha");
				} else if (savedTheme === "system") {
					const systemTheme = window.matchMedia(
						"(prefers-color-scheme: dark)",
					).matches
						? "dark"
						: "light";
					if (systemTheme === "dark") {
						document.documentElement.classList.add("mocha");
					}
				}
			})();
		</script>
	</head>
	<body>
		<!-- Theme Toggle Button -->
		<div
			class="no-print fixed z-50"
			style="
				top: max(1rem, env(safe-area-inset-top));
				right: max(1rem, calc(50vw - 32rem - 4rem));
			"
		>
			<button
				id="theme-toggle"
				class="bg-ctp-mantle border-ctp-surface0 hover:border-ctp-blue rounded-lg border p-2 transition-colors"
				title="Theme"
			>
				<svg
					id="theme-toggle-dark-icon"
					class="hidden h-5 w-5"
					fill="currentColor"
					viewBox="0 0 20 20"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
					></path>
				</svg>
				<svg
					id="theme-toggle-light-icon"
					class="hidden h-5 w-5"
					fill="currentColor"
					viewBox="0 0 20 20"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
						fill-rule="evenodd"
						clip-rule="evenodd"
					></path>
				</svg>
				<svg
					id="theme-toggle-system-icon"
					class="hidden h-5 w-5"
					fill="currentColor"
					viewBox="0 0 20 20"
					xmlns="http://www.w3.org/2000/svg"
				>
					<path
						fill-rule="evenodd"
						d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z"
						clip-rule="evenodd"
					></path>
				</svg>
			</button>
		</div>

		<div class="mx-auto max-w-5xl px-4 py-8 md:py-12">
			<!-- Header / Basics Section -->
			{{#if basics}}
			<header class="mb-8 md:mb-12">
				<div class="mb-4 flex flex-row items-center gap-4 md:gap-6">
					{{#if basics.image}}
					<img
						src="{{basics.image}}"
						alt="{{basics.name}}"
						class="border-ctp-surface0 h-20 w-20 shrink-0 rounded-full border-2 md:h-32 md:w-32"
					/>
					{{/if}}
					<div class="min-w-0 flex-1">
						<h1 class="mb-2 text-4xl font-bold">{{basics.name}}</h1>
						{{#if basics.label}}
						<p class="text-ctp-subtext0 text-xl">
							{{basics.label}}
						</p>
						{{/if}}
					</div>
				</div>
				{{#if basics.summary}}
				<p class="text-ctp-subtext0 mb-6 text-base leading-relaxed">
					{{basics.summary}}
				</p>
				{{/if}}

				<!-- Contact Information -->
				<div class="flex flex-wrap gap-3 text-sm md:gap-4">
					{{#if basics.email}}
					<a
						href="mailto:{{basics.email}}"
						class="text-ctp-blue flex items-center gap-2 hover:underline"
					>
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
							></path>
							<path
								d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
							></path>
						</svg>
						{{basics.email}}
					</a>
					{{/if}} {{#if basics.phone}}
					<a
						href="tel:{{basics.phone}}"
						class="text-ctp-blue flex items-center gap-2 hover:underline"
					>
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"
							></path>
						</svg>
						{{basics.phone}}
					</a>
					{{/if}} {{#if (or basics.url basics.website)}}
					<a
						href="{{#if basics.url}}{{basics.url}}{{else}}{{basics.website}}{{/if}}"
						target="_blank"
						rel="noopener noreferrer"
						class="text-ctp-blue flex items-center gap-2 hover:underline"
					>
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								fill-rule="evenodd"
								d="M12.586 4.586a2 2 0 112.828 2.828l-3 3a2 2 0 01-2.828 0 1 1 0 00-1.414 1.414 4 4 0 005.656 0l3-3a4 4 0 00-5.656-5.656l-1.5 1.5a1 1 0 101.414 1.414l1.5-1.5zm-5 5a2 2 0 012.828 0 1 1 0 101.414-1.414 4 4 0 00-5.656 0l-3 3a4 4 0 105.656 5.656l1.5-1.5a1 1 0 10-1.414-1.414l-1.5 1.5a2 2 0 11-2.828-2.828l3-3z"
								clip-rule="evenodd"
							></path>
						</svg>
						{{#if
						basics.url}}{{basics.url}}{{else}}{{basics.website}}{{/if}}
					</a>
					{{/if}} {{#if basics.location}}
					<span class="text-ctp-subtext0 flex items-center gap-2">
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 20 20"
						>
							<path
								fill-rule="evenodd"
								d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
								clip-rule="evenodd"
							></path>
						</svg>
						{{#if
						basics.location.city}}{{basics.location.city}}{{#if
						basics.location.region}}, {{/if}}{{/if}}{{#if
						basics.location.region}}{{basics.location.region}}{{/if}}{{#if
						basics.location.countryCode}}
						{{basics.location.countryCode}}{{/if}}
					</span>
					{{/if}}
				</div>

				<!-- Profiles -->
				{{#if basics.profiles}}
				<div class="mt-4 flex flex-wrap gap-3">
					{{#each basics.profiles}}
					<a
						href="{{url}}"
						target="_blank"
						rel="noopener noreferrer"
						class="bg-ctp-mantle border-ctp-surface0 hover:border-ctp-blue inline-flex items-center gap-2 rounded-md border px-3 py-1.5 text-sm transition-colors"
						title="{{network}}{{#if username}}: {{username}}{{/if}}"
					>
						<!-- GitHub Icon -->
						{{#if (eq network "GitHub")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							/>
						</svg>
						{{/if}}
						<!-- LinkedIn Icon -->
						{{#if (eq network "LinkedIn")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
							/>
						</svg>
						{{/if}}
						<!-- Npm Icon -->
						{{#if (eq network "NPM")}}
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="size-4"
							width="32"
							height="32"
							viewBox="0 0 24 24"
						>
							<!-- Icon from Simple Icons by Simple Icons Collaborators - https://github.com/simple-icons/simple-icons/blob/develop/LICENSE.md -->
							<path
								fill="currentColor"
								d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019l-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"
							/>
						</svg>
						{{/if}}
						<!-- Leetcode Icon -->
						{{#if (eq network "Leetcode")}}
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="size-4"
							width="32"
							height="32"
							viewBox="0 0 24 24"
						>
							<!-- Icon from Simple Icons by Simple Icons Collaborators - https://github.com/simple-icons/simple-icons/blob/develop/LICENSE.md -->
							<path
								fill="currentColor"
								d="M13.483 0a1.37 1.37 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.3 5.3 0 0 0-1.209 2.104a5 5 0 0 0-.125.513a5.5 5.5 0 0 0 .062 2.362a6 6 0 0 0 .349 1.017a5.9 5.9 0 0 0 1.271 1.818l4.277 4.193l.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.003-1.955a1.38 1.38 0 0 0-1.951-.003l-2.396 2.392a3.02 3.02 0 0 1-4.205.038l-.02-.019l-4.276-4.193c-.652-.64-.972-1.469-.948-2.263a2.7 2.7 0 0 1 .066-.523a2.55 2.55 0 0 1 .619-1.164L9.13 8.114c1.058-1.134 3.204-1.27 4.43-.278l3.501 2.831c.593.48 1.461.387 1.94-.207a1.384 1.384 0 0 0-.207-1.943l-3.5-2.831c-.8-.647-1.766-1.045-2.774-1.202l2.015-2.158A1.384 1.384 0 0 0 13.483 0m-2.866 12.815a1.38 1.38 0 0 0-1.38 1.382a1.38 1.38 0 0 0 1.38 1.382H20.79a1.38 1.38 0 0 0 1.38-1.382a1.38 1.38 0 0 0-1.38-1.382z"
							/>
						</svg>
						{{/if}}
						<!-- Bluesky Icon -->
						{{#if (eq network "Bluesky")}}
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="size-4"
							width="32"
							height="32"
							viewBox="0 0 24 24"
						>
							<!-- Icon from Simple Icons by Simple Icons Collaborators - https://github.com/simple-icons/simple-icons/blob/develop/LICENSE.md -->
							<path
								fill="currentColor"
								d="M5.202 2.857C7.954 4.922 10.913 9.11 12 11.358c1.087-2.247 4.046-6.436 6.798-8.501C20.783 1.366 24 .213 24 3.883c0 .732-.42 6.156-.667 7.037c-.856 3.061-3.978 3.842-6.755 3.37c4.854.826 6.089 3.562 3.422 6.299c-5.065 5.196-7.28-1.304-7.847-2.97c-.104-.305-.152-.448-.153-.327c0-.121-.05.022-.153.327c-.568 1.666-2.782 8.166-7.847 2.97c-2.667-2.737-1.432-5.473 3.422-6.3c-2.777.473-5.899-.308-6.755-3.369C.42 10.04 0 4.615 0 3.883c0-3.67 3.217-2.517 5.202-1.026"
							/>
						</svg>
						{{/if}}
						<!-- Twitter/X Icon -->
						{{#if (eq network "Twitter")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
							/>
						</svg>
						{{/if}} {{#if (eq network "X")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
							/>
						</svg>
						{{/if}}
						<!-- Instagram Icon -->
						{{#if (eq network "Instagram")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
							/>
						</svg>
						{{/if}}
						<!-- Facebook Icon -->
						{{#if (eq network "Facebook")}}
						<svg
							class="size-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
							/>
						</svg>
						{{/if}}
						<!-- YouTube Icon -->
						{{#if (eq network "YouTube")}}
						<svg
							class="h-4 w-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
							/>
						</svg>
						{{/if}}
						<!-- Default Icon for other networks -->
						{{#unless (or (eq network "Leetcode")(eq network
						"Bluesky") (eq network "NPM") (eq network "GitHub") (eq
						network "LinkedIn") (eq network "Twitter") (eq network
						"X") (eq network "Instagram") (eq network "Facebook")
						(eq network "YouTube"))}}
						<svg
							class="size-4"
							fill="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
							/>
						</svg>
						{{/unless}}
						<span>{{network}}</span>
					</a>
					{{/each}}
				</div>
				{{/if}}
			</header>
			{{/if}}

			<!-- Skills -->
			{{#if skills}}
			<section class="mb-8">
				<h2
					class="border-ctp-surface0 mb-4 border-b pb-2 text-2xl font-bold"
				>
					Skills
				</h2>
				<div class="grid grid-cols-1 gap-4 md:grid-cols-2">
					{{#each skills}}
					<div
						class="glass-tile bg-ctp-mantle border-ctp-surface0 rounded-lg border p-4"
					>
						<h3 class="mb-2 font-semibold">{{name}}</h3>
						{{#if keywords}}
						<div class="flex flex-wrap gap-2">
							{{#each keywords}}
							<span
								class="bg-ctp-base border-ctp-surface0 rounded border px-2 py-1 font-mono text-sm"
								>{{this}}</span
							>
							{{/each}}
						</div>
						{{/if}}
					</div>
					{{/each}}
				</div>
			</section>
			{{/if}}

			<!-- Work Experience -->
			{{#if work}}
			<section class="mb-8">
				<h2
					class="border-ctp-surface0 mb-4 border-b pb-2 text-2xl font-bold"
				>
					Work Experience
				</h2>
				<div class="space-y-6">
					{{#each work}}
					<div
						class="glass-tile bg-ctp-mantle border-ctp-surface0 rounded-lg border p-4 md:p-6"
					>
						<div
							class="mb-3 flex flex-col md:flex-row md:items-start md:justify-between"
						>
							<div>
								<h3 class="text-xl font-semibold">
									{{position}}
								</h3>
								<p class="text-ctp-subtext0">
									{{#if url}}<a
										href="{{url}}"
										target="_blank"
										rel="noopener noreferrer"
										class="text-ctp-blue hover:underline"
										>{{name}}</a
									>{{else}}{{name}}{{/if}} {{#if location}}
									<span
